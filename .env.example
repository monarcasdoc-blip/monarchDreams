RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Supabase project URL and publishable key — Project Settings > API
# (or the "Connect" button on the project dashboard).
# The publishable key is safe to expose to the browser; access is enforced
# by the Row Level Security policies in supabase/schema.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SECRET — Project Settings > API > service_role. Bypasses Row Level Security,
# so it must never be exposed to the browser (note: no NEXT_PUBLIC_ prefix).
# Used only by the server-side admin route to create official milkweed pins;
# that table has no anon write policy, which is what stops anyone from forging
# an "official" pin with the publishable key.
SUPABASE_SERVICE_ROLE_KEY=

# Password for /admin/milkweed, where Claudia adds official pins. Any long
# random string; share it with the team out of band.
MILKWEED_ADMIN_PASSWORD=

# Signs the admin session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this signs everyone out.
ADMIN_SESSION_SECRET=
