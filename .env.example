# Supabase project URL and publishable key — Project Settings > API
# (or the "Connect" button on the project dashboard).
# The publishable key is safe to expose to the browser; access is enforced
# by the Row Level Security policies in supabase/schema.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
